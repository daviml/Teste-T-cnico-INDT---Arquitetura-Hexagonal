# ---------------------------------------------------------------------------
# Exemplo de variáveis de ambiente.
# Copie para `.env` (que é git-ignored) e ajuste os valores para o seu ambiente.
#   cp .env.example .env
#
# Os valores abaixo são placeholders adequados a desenvolvimento LOCAL.
# Em produção, use segredos fortes e nunca os versione.
# ---------------------------------------------------------------------------

# ===== PostgreSQL =====
# Superusuário (bootstrap/administração do servidor).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# PropostaService — banco e usuário dedicados.
PROPOSTA_DB_NAME=propostas_db
PROPOSTA_DB_USER=proposta_app
PROPOSTA_DB_PASSWORD=proposta_dev_pwd

# ContratacaoService — banco e usuário dedicados.
CONTRATACAO_DB_NAME=contratacoes_db
CONTRATACAO_DB_USER=contratacao_app
CONTRATACAO_DB_PASSWORD=contratacao_dev_pwd

# ===== RabbitMQ =====
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
